<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane stylesheets="@../../../estilos.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.GestorVideojuegosHibernateJavaFX.controllers.MainController"> <center>
    <TableView fx:id="tabla" prefWidth="677.0" BorderPane.alignment="CENTER">
        <columns>
            <TableColumn fx:id="cId" prefWidth="50.0" text="ID" />
            <TableColumn fx:id="cTitulo" prefWidth="250.0" text="Título" />
            <TableColumn fx:id="cEstado" prefWidth="100.0" text="Estado" />
            <TableColumn fx:id="cSoporte" prefWidth="100.0" text="Soporte" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>
</center>
    <bottom>
        <FlowPane alignment="CENTER" hgap="20.0" prefWidth="499.0" BorderPane.alignment="CENTER">
            <children>
                <Button fx:id="btnAñadir" mnemonicParsing="false" onAction="#añadir" text="Añadir Copia" />
                <Button fx:id="btnBorrar" mnemonicParsing="false" onAction="#borrar" text="Borrar Copia" />
                <Button fx:id="btnEditar" mnemonicParsing="false" onAction="#editar" text="Modificar Copia" />

                <Button fx:id="btnNuevaPelicula" mnemonicParsing="false" onAction="#añadirPeliculaAdmin" text="Añadir Película (ADMIN)" />
            </children>
         <padding>
            <Insets bottom="10.0" top="10.0" />
         </padding>
        </FlowPane>
    </bottom>
    <top>
        <VBox alignment="CENTER" prefHeight="138.0" prefWidth="487.0" BorderPane.alignment="CENTER">
            <children>
                <Label fx:id="welcomeText" text="Gestor de Copias de Películas" />
                <Label fx:id="lblUsuario" text="Copias de películas del usuario: Nombre" />
            <HBox alignment="TOP_RIGHT" prefHeight="42.0" prefWidth="470.0" spacing="20.0">
               <children>
      
                      <Button fx:id="btnCerrar" mnemonicParsing="false" onAction="#cerrarSesion" text="Cerrar Sesión" />
                      <Button fx:id="btnSalir" mnemonicParsing="false" onAction="#salirAplicacion" text="Salir Aplicación" />
               </children>
               <VBox.margin>
                  <Insets bottom="5.0" top="5.0" />
               </VBox.margin>
               <padding>
                  <Insets bottom="5.0" top="5.0" />
               </padding>
            </HBox>
            </children>
        </VBox>
    </top>
   <padding>
      <Insets left="10.0" right="10.0" />
   </padding>
</BorderPane>
